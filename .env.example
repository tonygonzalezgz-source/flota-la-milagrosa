# ══════════════════════════════════════════════════
#  LA MILAGROSA — Variables de Entorno
#  Copia este archivo como ".env" y completa los valores
# ══════════════════════════════════════════════════

# ── BASE DE DATOS ──
# Sin esta variable → usa SQLite local (desarrollo)
# Con esta variable → usa Supabase PostgreSQL (producción)
#
# Obtén la URL en: Supabase → Settings → Database → Connection string → URI
# Reemplaza [TU-PASSWORD] con la contraseña de tu proyecto
#
DATABASE_URL=postgresql://postgres:[TU-PASSWORD]@db.[TU-PROJECT-REF].supabase.co:5432/postgres

# ── SERVIDOR ──
# Puerto del API Flask (por defecto 8001)
PORT=8001

# ── SEGURIDAD ──
# Clave secreta para firmar tokens JWT (¡CAMBIAR en producción!)
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-segura

# Horas de validez del token JWT (por defecto 12)
JWT_EXPIRY_HOURS=12

# Orígenes permitidos para CORS (en producción usar tu dominio exacto)
# Ejemplo: https://tu-app.onrender.com
ALLOWED_ORIGINS=*
